rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 인증된 사용자인지 확인
    function isAuthenticated() {
      return request.auth != null;
    }

    // 요청자가 해당 커플의 멤버인지 확인
    function isCoupleMe(coupleId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/couples/$(coupleId)) &&
        request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }

    // users: 본인만 쓰기, 같은 커플 멤버는 읽기 가능
    match /users/{userId} {
      allow write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.coupleId != null &&
          userId in get(/databases/$(database)/documents/couples/$(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.coupleId)).data.members
        )
      );
    }

    // inviteCodes: 초대 코드 → coupleId 매핑 (초대 코드 조회 전용)
    // couples 컬렉션을 누구나 읽는 대신 이 컬렉션으로 분리해 커플 데이터 노출 최소화
    match /inviteCodes/{code} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // 합류 시 joined: true 업데이트만 허용 (이미 사용된 코드 재사용 방지)
      allow update: if isAuthenticated() && !resource.data.joined;
      allow delete: if false;
    }

    // couples: 멤버만 읽기 가능, 생성은 인증된 사용자, 업데이트는 멤버만
    match /couples/{coupleId} {
      allow read: if isCoupleMe(coupleId);
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.members;
      allow update: if isAuthenticated() && (
        // 기존 멤버가 정보 수정 (기념일 등)
        request.auth.uid in resource.data.members ||
        // 새 멤버가 합류: 현재 멤버가 1명이고, 자기 자신을 추가하는 경우만 허용
        (resource.data.members.size() == 1 &&
         request.resource.data.members.hasAll(resource.data.members) &&
         request.auth.uid in request.resource.data.members)
      );
    }

    // events: 커플 공유 이벤트 (필수 필드 검증)
    // 'personal' 타입은 이 컬렉션에 존재하지 않음 — personal_events 컬렉션에 별도 저장
    match /events/{docId} {
      function isValidEvent() {
        return request.resource.data.title is string &&
          request.resource.data.title.size() > 0 &&
          request.resource.data.start is string &&
          request.resource.data.start.size() > 0 &&
          request.resource.data.eventType is string &&
          request.resource.data.eventType in ['couple', 'boyfriend', 'girlfriend', 'travel'];
      }

      allow read: if isAuthenticated() &&
        isCoupleMe(resource.data.coupleId);
      allow delete: if isAuthenticated() &&
        isCoupleMe(resource.data.coupleId);
      allow create: if isAuthenticated() &&
        isCoupleMe(request.resource.data.coupleId) &&
        isValidEvent();
      allow update: if isAuthenticated() &&
        isCoupleMe(resource.data.coupleId) &&
        isValidEvent();
    }

    match /edit_logs/{docId} {
      allow read: if isAuthenticated() && (
        resource.data.coupleId == null ||
        isCoupleMe(resource.data.coupleId)
      );
      allow create: if isAuthenticated() &&
        isCoupleMe(request.resource.data.coupleId);
      allow update: if false;
      allow delete: if false;
    }

    // trips: 여행 데이터 (필수 필드 검증)
    match /trips/{docId} {
      function isValidTrip() {
        return request.resource.data.title is string &&
          request.resource.data.title.size() > 0 &&
          request.resource.data.startDate != null &&
          request.resource.data.endDate != null;
      }

      allow read: if isAuthenticated() &&
        isCoupleMe(resource.data.coupleId);
      allow delete: if isAuthenticated() &&
        isCoupleMe(resource.data.coupleId);
      allow create: if isAuthenticated() &&
        isCoupleMe(request.resource.data.coupleId) &&
        isValidTrip();
      allow update: if isAuthenticated() &&
        isCoupleMe(resource.data.coupleId) &&
        isValidTrip();
    }

    match /tripSchedules/{docId} {
      allow read, write: if isAuthenticated() &&
        exists(/databases/$(database)/documents/trips/$(resource.data.tripId)) &&
        isCoupleMe(get(/databases/$(database)/documents/trips/$(resource.data.tripId)).data.coupleId);
      allow create: if isAuthenticated() &&
        exists(/databases/$(database)/documents/trips/$(request.resource.data.tripId)) &&
        isCoupleMe(get(/databases/$(database)/documents/trips/$(request.resource.data.tripId)).data.coupleId);
    }

    match /travelTimes/{docId} {
      allow read, write: if isAuthenticated() &&
        exists(/databases/$(database)/documents/trips/$(resource.data.tripId)) &&
        isCoupleMe(get(/databases/$(database)/documents/trips/$(resource.data.tripId)).data.coupleId);
      allow create: if isAuthenticated() &&
        exists(/databases/$(database)/documents/trips/$(request.resource.data.tripId)) &&
        isCoupleMe(get(/databases/$(database)/documents/trips/$(request.resource.data.tripId)).data.coupleId);
    }

    // bucketlists: 버킷리스트 (필수 필드 검증)
    match /bucketlists/{docId} {
      function isValidBucket() {
        return request.resource.data.title is string &&
          request.resource.data.title.size() > 0;
      }

      allow read: if isAuthenticated() &&
        isCoupleMe(resource.data.coupleId);
      allow delete: if isAuthenticated() &&
        isCoupleMe(resource.data.coupleId);
      allow create: if isAuthenticated() &&
        isCoupleMe(request.resource.data.coupleId) &&
        isValidBucket();
      allow update: if isAuthenticated() &&
        isCoupleMe(resource.data.coupleId) &&
        isValidBucket();
    }

    match /cycles/{docId} {
      allow read, write: if isAuthenticated() &&
        isCoupleMe(resource.data.coupleId);
      allow create: if isAuthenticated() &&
        isCoupleMe(request.resource.data.coupleId);
    }

    // 개인 캘린더: 소유자만 접근 가능
    match /personal_events/{docId} {
      allow read, write: if isAuthenticated() &&
        request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() &&
        request.auth.uid == request.resource.data.userId;
    }

    // 여행 선택지 (v0.3.51): 커플 멤버만 접근 가능
    match /trips/{tripId}/travelDecisions/{decisionId} {
      allow read: if isAuthenticated() &&
        exists(/databases/$(database)/documents/trips/$(tripId)) &&
        isCoupleMe(get(/databases/$(database)/documents/trips/$(tripId)).data.coupleId);
      allow create: if isAuthenticated() &&
        exists(/databases/$(database)/documents/trips/$(tripId)) &&
        isCoupleMe(get(/databases/$(database)/documents/trips/$(tripId)).data.coupleId);
      allow update: if isAuthenticated() &&
        exists(/databases/$(database)/documents/trips/$(tripId)) &&
        isCoupleMe(get(/databases/$(database)/documents/trips/$(tripId)).data.coupleId);
      allow delete: if isAuthenticated() &&
        exists(/databases/$(database)/documents/trips/$(tripId)) &&
        isCoupleMe(get(/databases/$(database)/documents/trips/$(tripId)).data.coupleId);
    }

    // 여행 체크리스트 (v0.3.51): 커플 멤버만 접근 가능
    match /trips/{tripId}/checklists/{checklistId} {
      allow read: if isAuthenticated() &&
        exists(/databases/$(database)/documents/trips/$(tripId)) &&
        isCoupleMe(get(/databases/$(database)/documents/trips/$(tripId)).data.coupleId);
      allow create: if isAuthenticated() &&
        exists(/databases/$(database)/documents/trips/$(tripId)) &&
        isCoupleMe(get(/databases/$(database)/documents/trips/$(tripId)).data.coupleId);
      allow update: if isAuthenticated() &&
        exists(/databases/$(database)/documents/trips/$(tripId)) &&
        isCoupleMe(get(/databases/$(database)/documents/trips/$(tripId)).data.coupleId);
      allow delete: if isAuthenticated() &&
        exists(/databases/$(database)/documents/trips/$(tripId)) &&
        isCoupleMe(get(/databases/$(database)/documents/trips/$(tripId)).data.coupleId);
    }
  }
}
