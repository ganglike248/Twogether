rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Firebase Storage Rules는 Firestore를 직접 쿼리할 수 없어
    // coupleId 소유권을 rules 레벨에서 검증하는 것은 불가능함.
    // 소유권 검증은 클라이언트 storageService.js의 validateCoupleIdAccess()에서 수행.
    // (Auth custom claims로 coupleId를 심으면 rules에서도 검증 가능하나 Cloud Functions 필요)

    // 이벤트 이미지: 경로 events/{coupleId}/{eventId}/{filename}
    match /events/{coupleId}/{eventId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // 커플 hero 이미지: 경로 couples/{coupleId}/hero
    match /couples/{coupleId}/hero {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // 기본: 차단
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
